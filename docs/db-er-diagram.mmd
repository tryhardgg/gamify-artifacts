    uuid id PK
    uuid artifact_id FK
    text stage
    timestamptz started_at
    timestamptz completed_at
    jsonb data
  }

  ARTIFACT_TASK_LINKS {
    uuid id PK
    uuid artifact_id FK
    uuid singularity_task_id FK
    text link_type
    timestamptz created_at
  }

  ARTIFACT_EVALUATIONS {
    uuid id PK
    uuid artifact_id FK
    jsonb criteria
    integer total_quality
    integer rarity
    timestamptz completed_at
  }

  ARTIFACT_REWARDS {
    uuid id PK
    uuid artifact_id FK
    bigint currency_amount
    uuid currency_transaction_id FK
    uuid granted_item_id FK
    integer granted_quantity
    timestamptz created_at
  }

