    uuid id PK
    text name
    text category
    jsonb rule
    bigint base_reward_currency
    uuid base_reward_item_id FK
    integer base_reward_quantity
    boolean is_active
    timestamptz created_at
  }

  HABITS {
    uuid id PK
    uuid player_id FK
    text name
    text description
    text type
    time target_time_from
    time target_time_to
    integer target_duration_minutes
    integer level
    numeric xp
    numeric xp_to_next_level
    integer streak_current
    integer streak_best
    jsonb short_term_buffs
    jsonb long_term_buffs
    bigint reward_currency
    uuid reward_item_id FK
    integer reward_quantity
    boolean is_active
    timestamptz created_at
    timestamptz updated_at
  }

  HABIT_LOGS {
    uuid id PK
    uuid habit_id FK
    uuid player_id FK
    date date
    text status
    numeric xp_earned
    integer streak_after
    text notes
    timestamptz created_at
  }

  HABIT_REWARDS {
    uuid id PK
    uuid habit_log_id FK
    uuid transaction_id FK
    uuid granted_item_id FK
    integer granted_quantity
    timestamptz created_at
  }

  SINGULARITY_TASKS {
    uuid id PK
    uuid player_id FK
    text external_id
    text title
    text description
    text status
    text[] tags
    jsonb raw_data
    timestamptz completed_at
    timestamptz created_at
    timestamptz updated_at
  }

  TASK_MAPPINGS {
    uuid id PK
    uuid player_id FK
    text[] tag_filter
    text artifact_category
    uuid artifact_template_id FK
    boolean is_active
    timestamptz created_at
    timestamptz updated_at
  }

  SYNC_LOGS {
    uuid id PK
    uuid player_id FK
    timestamptz started_at
    timestamptz finished_at
    integer tasks_fetched
    integer tasks_processed
    jsonb errors
    text status
  }

  SINGULARITY_HABITS {
    uuid id PK
    uuid player_id FK
    text external_id
    text name
    jsonb raw_data
    timestamptz created_at
    timestamptz updated_at
  }

  OKR_OBJECTIVES {
    uuid id PK
    uuid player_id FK
    text sphere
    text title
    text description
    text period
    integer weight
    text status
    timestamptz created_at
    timestamptz updated_at
  }

  OKR_KEY_RESULTS {
    uuid id PK
    uuid objective_id FK
    uuid player_id FK
    text sphere
    text title
    text type
    text unit
    date start_date
    date end_date
    numeric start_value
    numeric current_value
    numeric target_value
    numeric progress_percent
    numeric okr_score
    text status
    text comment
    timestamptz last_updated_at
  }

