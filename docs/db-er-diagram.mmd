erDiagram
  PLAYERS {
    uuid id PK
    uuid auth_user_id FK
    text username
    text avatar_url
    jsonb settings
    timestamptz created_at
    timestamptz updated_at
  }

  WALLETS {
    uuid id PK
    uuid player_id FK
    bigint balance
    text currency
    timestamptz created_at
    timestamptz updated_at
  }

  TRANSACTIONS {
    uuid id PK
    uuid wallet_id FK
    uuid player_id FK
    text type
    bigint amount
    text source_module
    uuid source_id
    text description
    timestamptz created_at
  }

  ITEMS {
    uuid id PK
    text code
    text name
    text description
    text rarity
    jsonb metadata
    timestamptz created_at
    timestamptz updated_at
  }

  INVENTORY_ITEMS {
    uuid id PK
    uuid player_id FK
    uuid item_id FK
    integer quantity
    timestamptz created_at
    timestamptz updated_at
  }

  PRODUCTS {
    uuid id PK
    text code
    text name
    text description
    bigint price
    text currency
    uuid item_id FK
    integer item_quantity
    integer stock_quantity
    integer stock_limit
    text category
    boolean is_active
    timestamptz created_at
    timestamptz updated_at
  }

